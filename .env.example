# Copy to .env for LOCAL testing of sync.py only.
# In production these live in GitHub Actions Secrets (sync) and Apps Script Script Properties (API).
# NEVER commit a real .env or a real token.

# --- Garmin auth (used by garmin-sync/sync.py) ---
# Base64 token blob from bootstrap_token.py. Generated ONCE locally (handles your 2FA),
# then stored as the GitHub Secret GARMIN_TOKENS_B64. Auto-refreshes ~1 year.
GARMIN_TOKENS_B64=base64-blob-printed-by-bootstrap_token.py

# Email/password are NOT used by sync.py — only by bootstrap_token.py interactively,
# typed at its prompts. Do not put your Garmin password in CI.

# --- Apps Script API (sync.py posts runs here) ---
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXX/exec
API_TOKEN=make-this-a-long-random-string

# --- Set these in Apps Script Script Properties, NOT here ---
# API_TOKEN     (same value as above)
# GITHUB_PAT    (fine-grained token, actions:write on this repo only)
# GITHUB_REPO   (e.g. thealexcleary/garmin-running-tracker)

# --- GitHub Actions Secrets to create (Settings -> Secrets -> Actions) ---
# GARMIN_TOKENS_B64   (from bootstrap_token.py)
# APPS_SCRIPT_URL     (same as above)
# API_TOKEN           (same as above)

# --- Frontend (set inside frontend/index.html, not via env) ---
# API_URL  = same as APPS_SCRIPT_URL
# API_TOKEN = same as API_TOKEN
